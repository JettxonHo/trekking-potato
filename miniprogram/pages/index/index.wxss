.container {
  padding: 40rpx 30rpx;
  min-height: 100vh;
  background: #f7f8f5;
}
.header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 60rpx;
}
.title {
  font-size: 56rpx;
  font-weight: bold;
  color: #2f7d5b;
}
.subtitle {
  font-size: 28rpx;
  color: #5d6b62;
  margin-top: 10rpx;
}
.form {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 40rpx;
}
.form-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1px solid #e2e6e0;
}
.form-item:last-child {
  border-bottom: none;
}
.label {
  width: 160rpx;
  font-size: 30rpx;
  color: #1f2a24;
  flex-shrink: 0;
}
.input {
  flex: 1;
  font-size: 30rpx;
  color: #1f2a24;
}
.picker {
  flex: 1;
  font-size: 30rpx;
  color: #1f2a24;
}
.picker.placeholder {
  color: #999;
}
.submit-btn {
  width: 100%;
  margin-bottom: 30rpx;
}
.error-box {
  background: #f8e9e6;
  border-radius: 12rpx;
  padding: 20rpx;
  text-align: center;
}
.error-box text {
  color: #a83a2b;
  font-size: 26rpx;
}

/* 分步 loading 样式 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 40rpx;
}
.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 6rpx solid #e2e6e0;
  border-top: 6rpx solid #2f7d5b;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 30rpx;
}
@keyframes spin {
  to { transform: rotate(360deg); }
}
.loading-text {
  font-size: 32rpx;
  color: #1f2a24;
  font-weight: bold;
  margin-bottom: 10rpx;
}
.loading-hint {
  font-size: 24rpx;
  color: #999;
}
