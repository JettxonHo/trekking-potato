.container {
  padding: 40rpx 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 60rpx;
}
.title {
  font-size: 56rpx;
  font-weight: bold;
  color: #2f7d5b;
}
.subtitle {
  font-size: 28rpx;
  color: #5d6b62;
  margin-top: 10rpx;
}
.test-btn {
  width: 80%;
  margin-bottom: 40rpx;
}
.error-box {
  background: #f8e9e6;
  border: 1px solid #e6c9c2;
  border-radius: 12rpx;
  padding: 20rpx;
  width: 90%;
}
.error-box text {
  color: #a83a2b;
  font-size: 26rpx;
}
.result-box {
  background: #e8f3ed;
  border: 1px solid #c7e3d3;
  border-radius: 12rpx;
  padding: 20rpx;
  width: 90%;
}
.result-label {
  font-size: 28rpx;
  font-weight: bold;
  color: #1f2a24;
}
.result-json {
  font-size: 28rpx;
  color: #2f7d5b;
  margin-left: 10rpx;
}
.result-meta {
  display: block;
  font-size: 26rpx;
  color: #5d6b62;
  margin-top: 10rpx;
}
