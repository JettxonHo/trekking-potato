<view class="container">
  <view class="header">
    <text class="title">徒步薯</text>
    <text class="subtitle">徒步行前建议助手</text>
  </view>

  <view class="form">
    <view class="form-item">
      <text class="label">路线名</text>
      <input class="input" placeholder="如：武功山、四姑娘山二峰" value="{{route}}" bindinput="onRouteInput" />
    </view>

    <view class="form-item">
      <text class="label">出发日期</text>
      <picker mode="date" start="{{minDate}}" value="{{date}}" bindchange="onDateChange">
        <view class="picker {{date ? '' : 'placeholder'}}">{{date || '请选择日期'}}</view>
      </picker>
    </view>

    <view class="form-item">
      <text class="label">天数</text>
      <input class="input" type="number" placeholder="1-7天" value="{{days}}" bindinput="onDaysChange" />
    </view>

    <view class="form-item">
      <text class="label">徒步水平</text>
      <picker mode="selector" range="{{levels}}" value="{{levelIndex}}" bindchange="onLevelChange">
        <view class="picker">{{levels[levelIndex]}}</view>
      </picker>
    </view>
  </view>

  <button class="submit-btn" type="primary" loading="{{loading}}" bindtap="onSubmit">
    获取行前建议
  </button>

  <view wx:if="{{error}}" class="error-box">
    <text>{{error}}</text>
  </view>
</view>
