.container { padding: 20rpx 24rpx 80rpx; background: #f7f8f5; min-height: 100vh; }

.degraded-banner {
  background: #a83a2b; color: #fff; padding: 20rpx; border-radius: 12rpx;
  text-align: center; margin-bottom: 20rpx; display: flex; flex-direction: column;
}
.degraded-banner text { font-size: 28rpx; font-weight: bold; }
.degraded-hint { font-size: 24rpx !important; font-weight: normal !important; opacity: 0.9; margin-top: 6rpx; }

.elevation-bar {
  background: #e8f3ed; border: 1px solid #c7e3d3; border-radius: 8rpx;
  padding: 12rpx 20rpx; margin-bottom: 20rpx; font-size: 26rpx; color: #2f7d5b;
}

.loading-box { text-align: center; padding: 80rpx; color: #5d6b62; }

.card {
  background: #fff; border-radius: 16rpx; padding: 24rpx; margin-bottom: 20rpx;
}
.card-title { font-size: 32rpx; font-weight: bold; color: #1f2a24; margin-bottom: 16rpx; }
.caveat { font-size: 22rpx; color: #b8651b; margin: 8rpx 0; padding: 8rpx; background: #fbf0e3; border-radius: 6rpx; }

.weather-day { display: flex; align-items: center; gap: 16rpx; padding: 8rpx 0; border-bottom: 1px solid #f0f2ee; font-size: 26rpx; }
.day-date { width: 160rpx; color: #1f2a24; }
.day-temp { width: 140rpx; color: #2f7d5b; font-weight: bold; }
.day-precip { width: 120rpx; color: #5d6b62; }
.day-wind { color: #5d6b62; }
.day-conf { color: #b8651b; font-size: 22rpx; }

.gear-section { margin-bottom: 16rpx; }
.gear-label { font-size: 28rpx; font-weight: bold; color: #2f7d5b; display: block; margin-bottom: 8rpx; }
.gear-label.essential { color: #a83a2b; }
.gear-item { display: flex; padding: 6rpx 0; font-size: 26rpx; }
.gear-name { width: 200rpx; color: #1f2a24; }
.gear-reason { flex: 1; color: #5d6b62; }

.risk-item { padding: 12rpx 0; border-bottom: 1px solid #f0f2ee; }
.risk-item.fatal { background: #f8e9e6; border-radius: 8rpx; padding: 12rpx; }
.risk-level { display: inline-block; font-size: 22rpx; padding: 2rpx 10rpx; border-radius: 10rpx; background: #eef2ee; color: #5d6b62; margin-right: 12rpx; }
.risk-level.fatal { background: #a83a2b; color: #fff; }
.risk-name { font-size: 28rpx; font-weight: bold; color: #1f2a24; }
.risk-advice { display: block; font-size: 26rpx; color: #5d6b62; margin-top: 4rpx; }
.risk-degraded { background: #f8e9e6; padding: 16rpx; border-radius: 8rpx; color: #a83a2b; font-size: 26rpx; }

.photo-row, .micro-row { display: flex; justify-content: space-between; padding: 6rpx 0; font-size: 26rpx; }

.note-item { font-size: 26rpx; color: #5d6b62; padding: 6rpx 0; }

.empty-hint { font-size: 24rpx; color: #999; text-align: center; padding: 16rpx; }

.disclaimer-box { background: #f0f2ee; border-radius: 12rpx; padding: 16rpx; margin: 20rpx 0; }
.disclaimer-box text { font-size: 22rpx; color: #5d6b62; }

.meta-box { display: flex; flex-direction: column; gap: 4rpx; padding: 12rpx; }
.meta-box text { font-size: 20rpx; color: #999; }

.retry-btn { margin-top: 20rpx; width: 100%; }
